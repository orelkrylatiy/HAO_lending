# ============================================================
#  HAO Лендинг — пример конфигурации
#  Скопируй этот файл в .env.local и заполни значения
#  $ cp .env.local.example .env.local
# ============================================================


# ── Telegram ─────────────────────────────────────────────────
# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=

# Получатели уведомлений — можно несколько через запятую
# Как узнать chat_id: напиши боту /start, открой
# https://api.telegram.org/bot<ТОКЕН>/getUpdates
# и найди "chat": { "id": 123... }
TELEGRAM_CHAT_IDS=1306687806


# ── Google Sheets ─────────────────────────────────────────────
# URL из Apps Script (Развернуть → Веб-приложение)
# Инструкция: см. SETUP.md
GOOGLE_SCRIPT_URL=


# ── Контакты на сайте (футер, ссылки) ────────────────────────
# NEXT_PUBLIC_ = значения видны в браузере, не пиши сюда токены!

NEXT_PUBLIC_CONTACT_PHONE=+7 (950) 6492906
NEXT_PUBLIC_CONTACT_PHONE_RAW=+79506492906
NEXT_PUBLIC_CONTACT_EMAIL=
NEXT_PUBLIC_CONTACT_TELEGRAM=https://t.me/haoznaet
NEXT_PUBLIC_CONTACT_WHATSAPP=https://wa.me/79506492906
